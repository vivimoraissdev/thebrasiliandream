# Secrets do Bot
BOT_SECRET=<YOUR_BOT_SECRET_HERE>
CRON_SECRET=<YOUR_CRON_SECRET_HERE>
ADMIN_AUDIT_SECRET=<YOUR_ADMIN_AUDIT_SECRET_HERE>

# Send e-mails to clients
RESEND_API_KEY=<YOUR_RESEND_API_KEY_HERE>

# New security validation from Cakto (Gap 1)
CAKTO_WEBHOOK_SECRET=<YOUR_CAKTO_WEBHOOK_SECRET_HERE>

# E-mail to receive Bot downtime alerts (Gap 2)
ADMIN_ALERT_EMAIL=<YOUR_ADMIN_ALERT_EMAIL_HERE>

# IMPORTANT (Gap 3): Ensure this URL uses HTTPS
BOT_SERVER_URL=<YOUR_BOT_SERVER_URL_HERE>

# Supabase
SUPABASE_URL=<YOUR_SUPABASE_URL_HERE>
SUPABASE_SERVICE_ROLE_KEY=<YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE>