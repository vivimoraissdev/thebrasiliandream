# Bot integration
# Must match BOT_SECRET in whatsapp-bot-brasiliandream.
BOT_SERVER_URL=<YOUR_BOT_SERVER_URL>
BOT_SECRET=<YOUR_BOT_SECRET>

# Scheduled jobs and protected administrative endpoints
CRON_SECRET=<YOUR_CRON_SECRET>
ADMIN_AUDIT_SECRET=<YOUR_ADMIN_AUDIT_SECRET>
ADMIN_NUMBERS=<YOUR_ADMIN_PHONE_NUMBERS_COMMA_SEPARATED>
AUDIT_MAX_REMOVALS=<MAX_REMOVALS_PER_DAY>

# Cakto webhook signature validation
CAKTO_WEBHOOK_SECRET=<YOUR_CAKTO_WEBHOOK_SECRET>

# Transactional e-mail and operational alerts
RESEND_API_KEY=<YOUR_RESEND_API_KEY>
RESEND_FROM_EMAIL=<YOUR_RESEND_FROM_EMAIL_ADDRESS>
ADMIN_ALERT_EMAIL=<YOUR_ADMIN_EMAIL_ADDRESS>

# Supabase server-side access
SUPABASE_URL=<YOUR_SUPABASE_URL>
SUPABASE_SERVICE_ROLE_KEY=<YOUR_SUPABASE_SERVICE_ROLE_KEY>
